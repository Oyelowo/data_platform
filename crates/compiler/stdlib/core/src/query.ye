// Yelang lazy query pipeline trait.
//
// `Queryable` is the optimizable, backend-agnostic pipeline interface. The
// compiler recognizes the trait via `@lang("queryable")` and lowers calls to
// its methods into QIR logical operators.
//
// Each `Queryable` method body calls `@intrinsic(query_*, ...)` so Phase 3 can
// extract the operator shape from typed THIR. The canonical wrapper type is
// `QueryArray<T>`.
//
// NOTE: The bootstrap compiler does not yet fully support `impl Trait` in
// return position or struct fields, so the signatures below use the trait path
// `Queryable<U>` instead of `impl Queryable<U>`. Once existential return types
// are supported, these should be rewritten to `impl Queryable<U>`.

@lang("queryable")
trait Queryable<T> {
    // Lazy transformations.
    @lang("queryable_map")
    fn map<U>(self, f: fn(T) -> U) -> Queryable<U>;
    @lang("queryable_filter")
    fn filter(self, pred: fn(&T) -> bool) -> Queryable<T>;
    @lang("queryable_flat_map")
    fn flat_map<U>(self, f: fn(T) -> Queryable<U>) -> Queryable<U>;

    // Ordering, grouping, slicing.
    @lang("queryable_order_by")
    fn order_by<K>(self, key: fn(T) -> K) -> Seq<T>;
    @lang("queryable_group_by")
    fn group_by<K>(self, key: fn(T) -> K) -> Queryable<Group<K, T>>;
    @lang("queryable_distinct")
    fn distinct(self) -> Queryable<T>;
    @lang("queryable_take")
    fn take(self, n: usize) -> Queryable<T>;
    @lang("queryable_skip")
    fn skip(self, n: usize) -> Queryable<T>;

    // Core aggregation hook.
    @lang("queryable_aggregate")
    fn aggregate<A, Acc, Out>(self, agg: A) -> Out
    where A: Aggregate<T, Acc, Out>;

    // Sugar methods.
    @lang("queryable_sum")
    fn sum(self) -> T
    where Self: Sized
    {
        self.aggregate(Sum {})
    }

    @lang("queryable_count")
    fn count(self) -> usize
    where Self: Sized
    {
        self.aggregate(Count {})
    }

    @lang("queryable_avg")
    fn avg(self) -> f64
    where Self: Sized
    {
        self.aggregate(Avg {})
    }

    @lang("queryable_min")
    fn min(self) -> Option<T>
    where Self: Sized
    {
        self.aggregate(Min {})
    }

    @lang("queryable_max")
    fn max(self) -> Option<T>
    where Self: Sized
    {
        self.aggregate(Max {})
    }

    // Eager fold/reduce.
    @lang("queryable_fold")
    fn fold<Acc>(self, init: Acc, f: fn(Acc, T) -> Acc) -> Acc;
    @lang("queryable_reduce")
    fn reduce(self, f: fn(T, T) -> T) -> Option<T>;

    // Force materialization.
    @lang("queryable_execute")
    fn execute(self) -> Vec<T>;
}

// Wrapper type: an array-backed lazy query plan. Each method body forwards to
// a compiler-recognized `@intrinsic` so the QIR extractor can emit the matching
// logical operator in Phase 3.
struct QueryArray<T> {
    plan: PlanId,
}

impl<T> Queryable<T> for QueryArray<T> {
    fn map<U>(self, f: fn(T) -> U) -> Queryable<U> {
        let plan: PlanId = @intrinsic(query_map(self.plan, f));
        QueryArray { plan }
    }

    fn filter(self, pred: fn(&T) -> bool) -> Queryable<T> {
        let plan: PlanId = @intrinsic(query_filter(self.plan, pred));
        QueryArray { plan }
    }

    fn flat_map<U>(self, f: fn(T) -> Queryable<U>) -> Queryable<U> {
        let plan: PlanId = @intrinsic(query_flat_map(self.plan, f));
        QueryArray { plan }
    }

    fn order_by<K>(self, key: fn(T) -> K) -> Seq<T> {
        let plan: PlanId = @intrinsic(query_order_by(self.plan, key));
        Seq { inner: QueryArray { plan } }
    }

    fn group_by<K>(self, key: fn(T) -> K) -> Queryable<Group<K, T>> {
        let plan: PlanId = @intrinsic(query_group_by(self.plan, key));
        QueryArray { plan }
    }

    fn distinct(self) -> Queryable<T> {
        let plan: PlanId = @intrinsic(query_distinct(self.plan));
        QueryArray { plan }
    }

    fn take(self, n: usize) -> Queryable<T> {
        let plan: PlanId = @intrinsic(query_take(self.plan, n));
        QueryArray { plan }
    }

    fn skip(self, n: usize) -> Queryable<T> {
        let plan: PlanId = @intrinsic(query_skip(self.plan, n));
        QueryArray { plan }
    }

    fn aggregate<A, Acc, Out>(self, agg: A) -> Out
    where A: Aggregate<T, Acc, Out>
    {
        @intrinsic(query_aggregate(self.plan, agg))
    }

    fn fold<Acc>(self, init: Acc, f: fn(Acc, T) -> Acc) -> Acc {
        @intrinsic(query_fold(self.plan, init, f))
    }

    fn reduce(self, f: fn(T, T) -> T) -> Option<T> {
        @intrinsic(query_reduce(self.plan, f))
    }

    fn execute(self) -> Vec<T> {
        @intrinsic(query_execute(self.plan))
    }
}

// Transitional impl for the built-in `Array<T>` type. This keeps existing code
// that calls aggregate methods directly on arrays working while the canonical
// `QueryArray<T>` wrapper is being adopted. The bodies are placeholders; QIR
// lowering intercepts calls on `Array<T>` and emits logical operators.
impl<T> Queryable<T> for Array<T> {
    fn filter(self, pred: fn(&T) -> bool) -> Queryable<T> { self }
    fn map<U>(self, f: fn(T) -> U) -> Queryable<U> { self }
    fn flat_map<U>(self, f: fn(T) -> Queryable<U>) -> Queryable<U> { self }
    fn order_by<K>(self, key: fn(T) -> K) -> Seq<T> { Seq { inner: self } }
    fn group_by<K>(self, key: fn(T) -> K) -> Queryable<Group<K, T>> { self }
    fn distinct(self) -> Queryable<T> { self }
    fn take(self, n: usize) -> Queryable<T> { self }
    fn skip(self, n: usize) -> Queryable<T> { self }
    fn aggregate<A, Acc, Out>(self, agg: A) -> Out
    where A: Aggregate<T, Acc, Out>
    {
        loop {}
    }
    fn sum(self) -> T where Self: Sized { self.aggregate(Sum {}) }
    fn count(self) -> usize where Self: Sized { self.aggregate(Count {}) }
    fn avg(self) -> f64 where Self: Sized { self.aggregate(Avg {}) }
    fn min(self) -> Option<T> where Self: Sized { self.aggregate(Min {}) }
    fn max(self) -> Option<T> where Self: Sized { self.aggregate(Max {}) }
    fn fold<Acc>(self, init: Acc, f: fn(Acc, T) -> Acc) -> Acc { init }
    fn reduce(self, f: fn(T, T) -> T) -> Option<T> { Option::None }
    fn execute(self) -> Vec<T> { self }
}

// Transitional impl so that ordered sequences can continue a query pipeline
// (e.g. `q.order_by(...).take(5)`). Methods forward to the inner queryable.
impl<T> Queryable<T> for Seq<T> {
    fn filter(self, pred: fn(&T) -> bool) -> Queryable<T> { self.inner.filter(pred) }
    fn map<U>(self, f: fn(T) -> U) -> Queryable<U> { self.inner.map(f) }
    fn flat_map<U>(self, f: fn(T) -> Queryable<U>) -> Queryable<U> { self.inner.flat_map(f) }
    fn order_by<K>(self, key: fn(T) -> K) -> Seq<T> { self.inner.order_by(key) }
    fn group_by<K>(self, key: fn(T) -> K) -> Queryable<Group<K, T>> { self.inner.group_by(key) }
    fn distinct(self) -> Queryable<T> { self.inner.distinct() }
    fn take(self, n: usize) -> Queryable<T> { self.inner.take(n) }
    fn skip(self, n: usize) -> Queryable<T> { self.inner.skip(n) }
    fn aggregate<A, Acc, Out>(self, agg: A) -> Out
    where A: Aggregate<T, Acc, Out>
    {
        self.inner.aggregate(agg)
    }
    fn sum(self) -> T where Self: Sized { self.inner.sum() }
    fn count(self) -> usize where Self: Sized { self.inner.count() }
    fn avg(self) -> f64 where Self: Sized { self.inner.avg() }
    fn min(self) -> Option<T> where Self: Sized { self.inner.min() }
    fn max(self) -> Option<T> where Self: Sized { self.inner.max() }
    fn fold<Acc>(self, init: Acc, f: fn(Acc, T) -> Acc) -> Acc { self.inner.fold(init, f) }
    fn reduce(self, f: fn(T, T) -> T) -> Option<T> { self.inner.reduce(f) }
    fn execute(self) -> Vec<T> { self.inner.execute() }
}

// Opaque plan handle. The compiler/runtime decides its representation.
struct PlanId;

// Ordered collection marker. `order_by` returns a `Seq` because only ordered
// inputs support range/slice without an explicit sort.
struct Seq<T> { inner: Queryable<T> }

// Result type of `group_by`. Each row is `{ key: K, items: Queryable<T> }`.
struct Group<K, T> { key: K, items: Queryable<T> }

// ---------------------------------------------------------------------------
// Intrinsic placeholders.
//
// The bodies above call `@intrinsic(query_*(...))`. During Phase 2 the
// bootstrap compiler still resolves the inner call expression, so we provide
// trivial placeholder functions with matching signatures. Phase 3 will intercept
// these `@intrinsic` calls in THIR and lower them to logical operators instead
// of invoking the placeholders.
// ---------------------------------------------------------------------------

fn query_map<T, U, F>(plan: PlanId, f: F) -> PlanId { plan }
fn query_filter<T, F>(plan: PlanId, pred: F) -> PlanId { plan }
fn query_flat_map<T, U, F>(plan: PlanId, f: F) -> PlanId { plan }
fn query_order_by<T, K, F>(plan: PlanId, key: F) -> PlanId { plan }
fn query_group_by<T, K, F>(plan: PlanId, key: F) -> PlanId { plan }
fn query_distinct<T>(plan: PlanId) -> PlanId { plan }
fn query_take<T>(plan: PlanId, n: usize) -> PlanId { plan }
fn query_skip<T>(plan: PlanId, n: usize) -> PlanId { plan }
fn query_aggregate<T, A, Acc, Out>(plan: PlanId, agg: A) -> Out
where A: Aggregate<T, Acc, Out>
{
    loop {}
}
fn query_fold<T, Acc, F>(plan: PlanId, seed: Acc, f: F) -> Acc { seed }
fn query_reduce<T, F>(plan: PlanId, f: F) -> Option<T> { Option::None }
fn query_execute<T>(plan: PlanId) -> Vec<T> { loop {} }
